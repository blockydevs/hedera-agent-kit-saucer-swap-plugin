# Hedera Account Configuration
# Your Hedera account ID (format: 0.0.xxxxx)
ACCOUNT_ID=0.0.xxxxx

# Your Hedera account private key in ECDSA format
# You can get this from your Hedera portal or wallet
PRIVATE_KEY=302e020100300506032b657004220420xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SaucerSwap API Configuration
# API key for accessing SaucerSwap REST API
# Contact SaucerSwap team or check their documentation for how to obtain this
SAUCERSWAP_API_KEY=your_saucerswap_api_key_here

# OpenAI API Configuration (for LangChain example)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
